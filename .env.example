APP_NAME=Habitat Calibre
# Docker host mount source path (used by compose volume interpolation)
CALIBRE_HOST_PATH=/Users/YOUR_USER/Dropbox/Library/eBooks/Calibre
# For Docker Compose, keep this as /library.
# For local dev, set this to your real Calibre root path.
CALIBRE_LIBRARY_PATH=/library
CALIBRE_CACHE_TTL_SECONDS=45
PORT=3000

# Session/auth
# Must be at least 32 chars in production.
SESSION_SECRET=change-this-to-a-long-random-secret
# allowlist | shared | allowlist_or_shared
AUTH_PLEX_MODE=allowlist_or_shared
# Comma-separated list of trusted Plex account emails
PLEX_ALLOWED_EMAILS=
# Plex server machine identifier (required for shared access checks)
PLEX_SERVER_MACHINE_ID=
# Optional Plex client identifier for server-side Plex API calls
PLEX_CLIENT_IDENTIFIER=

# Request delivery mode: telegram | lazylibrarian | shelfmark | both
REQUEST_DELIVERY_MODE=lazylibrarian
# LazyLibrarian external instance
LAZYLIBRARIAN_BASE_URL=http://lazylibrarian:5299
LAZYLIBRARIAN_API_KEY=
# Optional confidence threshold (0-100)
LAZYLIBRARIAN_MATCH_THRESHOLD=84

# Shelfmark request integration (service account)
SHELFMARK_BASE_URL=http://shelfmark:8084
SHELFMARK_USERNAME=
SHELFMARK_PASSWORD=
# Optional HTTP timeout in milliseconds
SHELFMARK_HTTP_TIMEOUT_MS=12000

# Request-a-book Telegram bot delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: forum topic thread id
TELEGRAM_THREAD_ID=
