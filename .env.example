APP_NAME=Habitat Calibre
# Docker host mount source path (used by compose volume interpolation)
CALIBRE_HOST_PATH=/Users/YOUR_USER/Dropbox/Library/eBooks/Calibre
# For Docker Compose, keep this as /library.
# For local dev, set this to your real Calibre root path.
CALIBRE_LIBRARY_PATH=/library
CALIBRE_CACHE_TTL_SECONDS=45
PORT=3000
